---
const rawLink = Astro.props.link || '';
let link;
if (/^https?:\/\//i.test(rawLink.replace(/^\/+/, ''))) {
  link = rawLink.replace(/^\/+/, '');
} else if (rawLink.startsWith('#') || rawLink.startsWith('mailto:') || rawLink.startsWith('tel:')) {
  link = rawLink;
} else {
  link = import.meta.env.BASE_URL + rawLink.replace(/^\/+/, '');
}

const rawImg = Astro.props.img || '';
let img;
if (/^https?:\/\//i.test(rawImg.replace(/^\/+/, ''))) {
  img = rawImg.replace(/^\/+/, '');
} else {
  img = import.meta.env.BASE_URL + rawImg.replace(/^\/+/, '');
}
const { img_alt } = Astro.props;

// text is in slot

---

<a href= {link} class="link-card" rel="noopener noreferrer">
    <div class="card-image">
        <img src= {img} alt={img_alt}/>
    </div>
    <div class="card-text">
        <slot/>
    </div>
</a>

<style>
.link-card {
    max-width: 420px;
    display: grid;
    padding: 0rem 0rem;
    align-items: center;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.45);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(128, 128, 128, 0.12);
    border-radius: 16px;
    color: var(--text-color) !important;
    box-shadow: 
      0 4px 6px -1px rgba(0, 0, 0, 0.02),
      0 10px 15px -3px rgba(0, 0, 0, 0.03);
    transition: 
      transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), 
      background-color 0.25s ease, 
      border-color 0.25s ease,
      box-shadow 0.3s ease;
  }
  .link-card:hover {
    transform: translateY(-4px) scale(1.015);
    background: rgba(255, 255, 255, 0.7);
    border-color: rgba(129, 140, 248, 0.3);
    box-shadow: 
      0 10px 20px -5px rgba(129, 140, 248, 0.15),
      0 8px 8px -6px rgba(0, 0, 0, 0.05);
  }

  @media (prefers-color-scheme: dark) {
    .link-card {
      background: var(--card-background);
    }
    .link-card:hover {
      background: rgba(1, 9, 28, 0.7);
      border-color: rgba(129, 140, 248, 0.3);
      box-shadow: 
        0 10px 20px -5px rgba(174, 182, 255, 0.3),
        0 8px 8px -6px rgba(0, 0, 0, 0.05);
    }
  }

  img {
    display: flex;
    margin: auto;
    border-radius: 16px;
    width: 100%;
    height: 360px;
    object-fit: cover;
  }

  .card-text {
    flex: 1;
    padding-left: 1.2rem;
    padding-right: 1.2rem;
    padding-top: 1rem;
    padding-bottom: 1.3rem;
    text-align: center;
  }

  .card-text h3 {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.15rem;
  }
  .card-text p {
    font-size: 0.85rem;
    opacity: 0.7;
    font-weight: 400;
    line-height: 1.4;
  }
</style>