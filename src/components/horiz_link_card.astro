---
const { link } = Astro.props;
const { icon } = Astro.props;
const { title } = Astro.props;
const { text } = Astro.props;
---

<a href= { link } class="link-card" target="_blank" rel="noopener noreferrer">
    <div class="card-icon">
    <i class="material-icons">{icon}</i>
    </div>
    <div class="card-text">
    <h3>{title}</h3>
    <p> {text} </p>
    </div>
    <div class="card-arrow">
    <i class="material-icons">east</i>
    </div>
</a>

<style>
    .link-card {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.1rem 1.4rem;
        text-decoration: none;
        background: rgba(255, 255, 255, 0.45);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(128, 128, 128, 0.12);
        border-radius: 16px;
        color: var(--text-color) !important;
        box-shadow: 
        0 4px 6px -1px rgba(0, 0, 0, 0.02),
        0 10px 15px -3px rgba(0, 0, 0, 0.03);
        transition: 
        transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), 
        background-color 0.25s ease, 
        border-color 0.25s ease,
        box-shadow 0.3s ease;
    }
    @media (prefers-color-scheme: dark) {
        .link-card {
        background: rgba(1, 9, 28, 0.45);
        border-color: rgba(255, 255, 255, 0.06);
        }
    }
    .link-card:hover {
        transform: translateY(-4px) scale(1.015);
        background: rgba(255, 255, 255, 0.7);
        border-color: rgba(129, 140, 248, 0.3);
        box-shadow: 
        0 10px 20px -5px rgba(129, 140, 248, 0.15),
        0 8px 8px -6px rgba(0, 0, 0, 0.05);
    }
    @media (prefers-color-scheme: dark) {
        .link-card:hover {
        background: rgba(1, 9, 28, 0.7);
        border-color: rgba(129, 140, 248, 0.3);
        box-shadow: 
            0 10px 20px -5px rgba(129, 140, 248, 0.3),
            0 8px 8px -6px rgba(0, 0, 0, 0.05);
        }
    }
    .card-icon {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 44px;
        height: 44px;
        border-radius: 12px;
        background-color: rgba(129, 140, 248, 0.08);
        color: var(--accent-color-1);
        transition: transform 0.3s ease, background-color 0.3s ease, color 0.3s ease;
    }
    .link-card:hover .card-icon {
        transform: scale(1.1);
        background-color: var(--accent-color-1);
        color: #fff;
    }
    .card-text {
        flex: 1;
        margin-left: 1.2rem;
        text-align: left;
    }
    .card-text h3 {
        font-size: 1.05rem;
        font-weight: 700;
        margin-bottom: 0.15rem;
    }
    .card-text p {
        font-size: 0.85rem;
        opacity: 0.7;
        font-weight: 400;
        line-height: 1.4;
    }
    .card-arrow {
        display: flex;
        align-items: center;
        color: var(--text-color);
        opacity: 0.3;
        transition: opacity 0.25s ease, transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .link-card:hover .card-arrow {
        opacity: 0.8;
        color: var(--accent-color-1);
        transform: translateX(5px);
    }
</style>