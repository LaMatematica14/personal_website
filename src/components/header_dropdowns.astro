---
const { title } = Astro.props;
const { main_page } = Astro.props;
const { options } = Astro.props;
const {target = '_self'} = Astro.props;
---

<div class="dropdown">
    <span class="dropdown-trigger">
        <b> <a href={main_page} target={target}> {title} </a> </b> 
    </span>
    <div class="dropdown-menu">  
    {options.map(item => (
        <a href={item.url}> {item.label} </a>
    ))}
    </div>
</div>

<style>
    /* Dropdown container */
    .dropdown {
        position: relative;
        display: inline-block;
    }

    /* Dropdown Trigger */
    .dropdown-trigger {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        margin-left: 2.7rem;
        text-decoration: none;
        color: var(--text-color);
        transition: color 0.2s ease;
        cursor: pointer;
        padding: 0.5rem 0;
    }


    /* Glassmorphism Dropdown Menu */
  .dropdown-menu {
    position: absolute;
    top: 100%;
    left: 1.5rem; /* align with trigger text margin */
    min-width: 220px;
    background: rgba(255, 255, 255, 0.75);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(128, 128, 128, 0.15);
    border-radius: 12px;
    box-shadow: 
      0 4px 6px -1px rgba(0, 0, 0, 0.05), 
      0 10px 30px -5px rgba(0, 0, 0, 0.08),
      inset 0 1px 0 0 rgba(255, 255, 255, 0.5);
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px) scale(0.98);
    transition: 
      opacity 0.25s cubic-bezier(0.4, 0, 0.2, 1), 
      transform 0.25s cubic-bezier(0.4, 0, 0.2, 1), 
      visibility 0.25s;
    z-index: 100;
    display: flex;
    flex-direction: column;
    padding: 0.5rem;
    margin-top: 0.25rem;
  }

  /* Dark mode glassmorphism */
  @media (prefers-color-scheme: dark) {
    .dropdown-menu {
      background: rgba(1, 9, 28, 0.75);
      border-color: rgba(255, 255, 255, 0.08);
      box-shadow: 
        0 4px 6px -1px rgba(0, 0, 0, 0.2), 
        0 10px 30px -5px rgba(0, 0, 0, 0.4),
        inset 0 1px 0 0 rgba(255, 255, 255, 0.05);
    }
  }

  /* Show dropdown on hover only */
  .dropdown:hover .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
  }

  /* Dropdown Links */
  .dropdown-menu a {
    margin: 0 !important;
    padding: 0.6rem 1rem;
    font-size: 0.9rem;
    color: var(--text-color);
    transition: background-color 0.2s ease, color 0.2s ease, transform 0.15s ease;
    border-radius: 8px;
    display: block;
    font-weight: 500;
    text-align: left;
  }

  .dropdown-menu a:hover {
    background-color: rgba(129, 140, 248, 0.12); /* Subtle accent color background */
    color: var(--accent-color-1);
    transform: translateX(4px); /* Sleek shift animation */
  }

  /* Smooth focus ring for accessibility */
  .dropdown-trigger:focus-visible,
  .dropdown-menu a:focus-visible {
    outline: 2px solid var(--accent-color-1);
    outline-offset: 2px;
    border-radius: 4px;
  }

</style>