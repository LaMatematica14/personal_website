---
// 1. FRONTMATTER: Handle page-specific metadata passed down as props
interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "LaMatematica14 si presenta", 
  description = "Welcome to my personal corner of the internet." 
} = Astro.props;

import '@fontsource/merriweather';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-16" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="stylesheet" href="https://fonts.googleapis.com/icon?family=Material+Icons">
  </head>
  

  <body>
    <div class="layout-wrapper">
      <header class="site-header">
        <nav class="nav-container">
          <a href="/" class="logo"><i class="material-icons">home</i></a>
          <div class="nav-links">

            <a href="/about"> <b> Chi sono? </b> </a>

            <div class="dropdown">
              <span class="dropdown-trigger">
                <b>Progetti</b> <span class="chevron">▼</span>
              </span>
              <div class="dropdown-menu">
                <a href="/progetti/cp"> Programmazione Competitiva </a>
                <a href="/progetti/f1inschools">F1inSchools</a>
                <a href="/progetti/scolastici">Elaborati scolastici</a>
                <a href="/progetti/musica"> Musica </a>
              </div>
            </div>

            <div class="dropdown">
              <span class="dropdown-trigger">
                <b>FSL</b> <span class="chevron">▼</span>
              </span>
              <div class="dropdown-menu">
                <a href="/PresentazioneFSL.pdf" target="_blank" rel="noopener noreferrer"> Presentazione </a>
                <a href="/fsl#google">Stage Google Zurigo</a>
                <a href="/fsl#egmo_camp"> EGMO Camp </a>
                <a href="/fsl#mathesis"> Stage Mathesis </a>
                <a href="/fsl#aif"> Stage AIF </a>
                <a href="/fsl#scolastici"> A scuola </a>
              </div>
            </div>

            <div class="dropdown">
              <span class="dropdown-trigger">
                <b>Riconoscimenti</b> <span class="chevron">▼</span>
              </span>
              <div class="dropdown-menu">
                <a href="/riconoscimenti/olimpiadi_informatica">Olimpiadi di informatica</a>
                <a href="/riconoscimenti/olimpiadi_fisica">Olimpiadi di fisica</a>
                <a href="/riconoscimenti/altro"> Altri premi</a>
              </div>
            </div>

            <a href="/links"> <b> Altri link </b></a>
          </div>
        </nav>
      </header>
      

      <main class="main-content">
        <!-- 2. THE SLOT: This is where your page content goes -->
        <slot />
      </main>

      <footer class="site-footer">
        <p>&copy; {new Date().getFullYear()} — Built with Astro</p>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  /* 3. GLOBAL STYLES: Base resets and design tokens */
  :root {
    --bg-color: #ffffff;
    --text-color: #1a1a1a;
    --accent-color-1: #818cf8;
    --accent-color-2: #818cf8;
    --max-width: 2400px;
  }

  /* Dark mode support out of the box */
  @media (prefers-color-scheme: dark) {
    :root {
      --bg-color: #01091c; /* Slate 900 */
      --text-color: #f8fafc;
      --accent-color-1: #8891df;
      --accent-color-2: #101a7a;
    }
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    background-color: var(--bg-color);
    color: var(--text-color);
    font-family: 'Merriweather', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
  }

  /* Layout Constraints */
  .layout-wrapper {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    max-width: var(--max-width);
    margin: 0;
    padding: 0 1.5rem;
  }

  .main-content {
    flex: 1; /* Pushes the footer to the bottom of the page */
    padding: 2rem 0;
  }

  .centered {
    text-align: center;
  }

  /* Header Navigation styling */
  .site-header {
    padding: 1.5rem 0;
    width: 100%;
  }

  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-weight: 700;
    text-decoration: none;
    color: var(--text-color);
  }

  /* Navigation styling */
  .nav-links {
    display: flex;
    align-items: center;
  }

  .nav-links a {
    text-decoration: none;
    color: var(--text-color);
    transition: color 0.2s ease;
  }

  .nav-links > a {
    margin-left: 1.5rem;
  }

  .nav-links a:hover {
    color: var(--accent-color-1);
  }

  /* Dropdown container */
  .dropdown {
    position: relative;
    display: inline-block;
  }

  /* Dropdown Trigger */
  .dropdown-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-left: 1.5rem;
    text-decoration: none;
    color: var(--text-color);
    transition: color 0.2s ease;
    cursor: pointer;
    padding: 0.5rem 0;
  }

  .chevron {
    font-size: 0.65rem;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0.7;
    display: inline-block;
  }

  .dropdown:hover .chevron {
    transform: rotate(180deg);
  }

  /* Glassmorphism Dropdown Menu */
  .dropdown-menu {
    position: absolute;
    top: 100%;
    left: 1.5rem; /* align with trigger text margin */
    min-width: 230px;
    background: rgba(255, 255, 255, 0.75);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(128, 128, 128, 0.15);
    border-radius: 12px;
    box-shadow: 
      0 4px 6px -1px rgba(0, 0, 0, 0.05), 
      0 10px 30px -5px rgba(0, 0, 0, 0.08),
      inset 0 1px 0 0 rgba(255, 255, 255, 0.5);
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px) scale(0.98);
    transition: 
      opacity 0.25s cubic-bezier(0.4, 0, 0.2, 1), 
      transform 0.25s cubic-bezier(0.4, 0, 0.2, 1), 
      visibility 0.25s;
    z-index: 100;
    display: flex;
    flex-direction: column;
    padding: 0.5rem;
    margin-top: 0.25rem;
  }

  /* Dark mode glassmorphism */
  @media (prefers-color-scheme: dark) {
    .dropdown-menu {
      background: rgba(1, 9, 28, 0.75);
      border-color: rgba(255, 255, 255, 0.08);
      box-shadow: 
        0 4px 6px -1px rgba(0, 0, 0, 0.2), 
        0 10px 30px -5px rgba(0, 0, 0, 0.4),
        inset 0 1px 0 0 rgba(255, 255, 255, 0.05);
    }
  }

  /* Show dropdown on hover only */
  .dropdown:hover .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
  }

  /* Dropdown Links */
  .dropdown-menu a {
    margin: 0 !important;
    padding: 0.6rem 1rem;
    font-size: 0.9rem;
    color: var(--text-color);
    transition: background-color 0.2s ease, color 0.2s ease, transform 0.15s ease;
    border-radius: 8px;
    display: block;
    font-weight: 500;
    text-align: left;
  }

  .dropdown-menu a:hover {
    background-color: rgba(129, 140, 248, 0.12); /* Subtle accent color background */
    color: var(--accent-color-1);
    transform: translateX(4px); /* Sleek shift animation */
  }

  /* Smooth focus ring for accessibility */
  .dropdown-trigger:focus-visible,
  .dropdown-menu a:focus-visible {
    outline: 2px solid var(--accent-color-1);
    outline-offset: 2px;
    border-radius: 4px;
  }

  .site-footer {
    padding: 2rem 0;
    text-align: center;
    font-size: 0.875rem;
    opacity: 0.7;
    border-top: 1px solid rgba(128, 128, 128, 0.2);
  }
</style>