---
// 1. FRONTMATTER: Handle page-specific metadata passed down as props
interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "LaMatematica14 si presenta", 
  description = "Welcome to my personal corner of the internet." 
} = Astro.props;


import '@fontsource/merriweather';
import HeaderDropdowns from '../components/header_dropdowns.astro';'../components/header_dropdowns.astro'
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-16" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="stylesheet" href="https://fonts.googleapis.com/icon?family=Material+Icons">
  </head>
  

  <body>
    <div class="layout-wrapper">
      <header class="site-header">
        <nav class="nav-container">
          <a href="/" class="logo"><i class="material-icons">home</i></a>
          <div class="nav-links">

            <a href="/about" style="padding-left: 1rem"> <b> Chi sono? </b> </a>

            <a href="/viaggi"style="padding-left: 1rem"> <b> Viaggi</b> </a>

            <HeaderDropdowns title = "Progetti" main_page = '/progetti/intro'
              options = {[
                { label: 'Programmazione competitiva', url: '/progetti/cp' },
                { label: 'F1inSchools', url: '/progetti/f1inschools' },
                { label: 'SWERC', url: '/progetti/swerc' },
                { label: 'Scolastici', url: '/progetti/scolastici' },
                { label: 'Musica', url: '/progetti/arte'}
              ]}
            />

            <HeaderDropdowns title="FSL" main_page = '/fsl/intro'
              options={[
                { label: 'Presentazione', url: '/PresentazioneFSL.pdf' },
                { label: 'Stage Google', url: '/fsl#google' },
                { label: 'EGMO Camp', url: '/fsl#egmo_camp' },
                { label: 'Stage di matematica e fisica', url: '/fsl#aif_e_mathesis' },
                { label: 'A scuola', url: '/fsl#scolastici' }
              ]} 
            />

            <HeaderDropdowns title="Riconoscimenti"  main_page = '/riconoscimenti/intro'
              options={[
                { label: 'Olimpiadi di informatica', url: '/olinfo/intro' },
                { label: 'Olimpiadi di fisica', url: '/riconoscimenti/olifis' },
                { label: 'Altri premi', url: '/riconoscimenti/altro' }
              ]} 
            />

            <a href="/links" style="padding-left: 1rem"> <b> Altri link </b></a>
          </div>
        </nav>
      </header>
      
      <slot />

      <footer class="site-footer">
        <p>&copy; {new Date().getFullYear()} — Built with Astro</p>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  :root {
    --bg-color: #ffffff;
    --text-color: #1a1a1a;
    --card-background: #818cf8;
    --accent-color-1: #818cf8;
    --accent-color-2: #818cf8;
    --max-width: 2400px;
  }

  /* Dark mode support out of the box */
  @media (prefers-color-scheme: dark) {
    :root {
      --bg-color: #050910; 
      --card-background: #050f21;
      --text-color: #f8fafc;
      --accent-color-1: #6672d9;
      --accent-color-2: #101a7a;
    }
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    background-color: var(--bg-color);
  }

  body {
    background-color: var(--bg-color);
    color: var(--text-color);
    font-family: 'Merriweather', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
  }

  /* Layout Constraints */
  .layout-wrapper {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    max-width: var(--max-width);
    margin: 0;
  }

  .centered {
    text-align: center;
  }

  /* Header Navigation styling */
  .site-header {
    background-color: var(--bg-color);
    padding-top: 1.2rem;
    padding-right: 2rem;
    padding-left: 1.7rem;
    padding-bottom: 0.3rem;

    width: 100%;
  }

  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-weight: 700;
    scale: 120%;
    padding: 0.7% 1%;
    text-decoration: none;
    color: var(--text-color);
  }
  .logo :hover {
    color: var(--accent-color-1);
  }

  /* Navigation styling */
  .nav-links {
    display: flex;
    align-items: center;
  }

  .nav-links a {
    text-decoration: none;
    color: var(--text-color);
    transition: color 0.2s ease;
  }

  .nav-links > a {
    margin-left: 1.5rem;
  }

  .nav-links a:hover {
    color: var(--accent-color-1);
  }

  .site-footer {
    padding: 2rem 0;
    background-color: var(--bg-color);
    text-align: center;
    font-size: 0.875rem;
    border-top: 1px solid rgba(128, 128, 128, 0.2);
  }
</style>