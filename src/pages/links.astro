---
import BaseLayout from '../layouts/base.astro';
import LinkCard from '../components/horiz_link_card.astro'
---
<BaseLayout title="Altri link" description="I miei contatti, profili e risorse">
  <div class="links-page-wrapper">

    <div class="links-content">  
      <div class="links-grid">
        <!-- Section 1: Code & Competitive Programming -->
        <div class="links-section">
          <h2><span class="section-emoji">💻</span> Codice & Competizioni</h2>
          <div class="cards-list">
            <LinkCard 
              link = "https://github.com/LaMatematica14" 
              title = "GitHub" 
              text = "I miei progetti e le mie repository"
              icon = "code"
            />
            
            <LinkCard 
              link="https://training.olinfo.it/user/LaMatematica14" 
              title="Olinfo Training"  
              text="Profilo di allenamento delle OII" 
              icon = "code"
            />

            <LinkCard 
              link="https://codeforces.com/profile/LaMatematica14" 
              title="Codeforces"  
              text="Piattaforma internazionale di programmazione competitiva" 
              icon = "code"
            />
          </div>
        </div>
        <!-- Section 2: Socials & Contact -->
        <div class="links-section">
          <h2><span class="section-emoji">🌐</span> Social & Contatti</h2>
          <div class="cards-list">
            <LinkCard 
              link="https://it.linkedin.com/in/sofia-maragò-5507bb34b" 
              title="LinkedIn"  
              text="Rete professionale e connessioni" 
              icon="people"
              cardClass="linkedin-card"
            />
            <LinkCard 
              link="mailto:sofia.marago@gmail.com" 
              title="Scrivimi un'e-mail"  
              text="sofia.marago@gmail.com" 
              icon="email"
              cardClass="email-card"
            />
          </div>
        </div>
        <!-- Section 3: CV & Download -->
        <div class="links-section cv-section">
          <h2><span class="section-emoji">📄</span> Curriculum Vitae</h2>
          <a href="#" class="cv-download-button">
            <div class="cv-btn-content">
              <i class="material-icons download-icon">download</i>
              <div class="cv-btn-text">
                <h3>Scarica il mio CV</h3>
                <p> Aggiornato a Maggio 2026</p>
              </div>
            </div>
            <i class="material-icons arrow-down">arrow_downward</i>
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>


<style>
  .links-page-wrapper {
    position: relative;
    width: 100%;
    min-height: 80vh;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding: 2rem 0;
    overflow: hidden;
  }
  /* Whimsical Background Glyphs */
  .whimsical-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }
  .glyph {
    position: absolute;
    top: var(--y);
    left: var(--x);
    font-size: var(--s);
    color: var(--accent-color-1);
    opacity: 0.15;
    font-family: 'JetBrains Mono', monospace;
    animation: drift 10s ease-in-out infinite alternate;
    animation-delay: var(--d);
    user-select: none;
    transition: opacity 0.3s ease;
  }
  @keyframes drift {
    0% {
      transform: translate(0, 0) rotate(0deg);
    }
    100% {
      transform: translate(15px, 20px) rotate(15deg);
    }
  }
  .links-page-wrapper:hover .glyph {
    opacity: 0.25;
    color: var(--accent-color-1);
  }
  .links-content {
    position: relative;
    width: 100%;
    max-width: 650px;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
  }
  
  /* Links Grid & Sections */
  .links-grid {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }
  .links-section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .links-section h2 {
    font-size: 1.1rem;
    font-weight: 700;
    opacity: 0.85;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .section-emoji {
    font-size: 1.3rem;
  }
  .cards-list {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  /* Link Card - Beautiful Glassmorphic Styles */
  
  /* CV Download Button Styling */
  .cv-download-button {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.2rem 1.5rem;
    text-decoration: none;
    background: linear-gradient(135deg, rgba(129, 140, 248, 0.12) 0%, rgba(255, 133, 162, 0.08) 100%);
    border: 1px solid rgba(129, 140, 248, 0.2);
    border-radius: 18px;
    color: var(--text-color) !important;
    box-shadow: 
      0 4px 15px -3px rgba(129, 140, 248, 0.06);
    transition: 
      transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), 
      background 0.3s ease, 
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }
  .cv-download-button:hover {
    transform: translateY(-4px) scale(1.015);
    background: linear-gradient(135deg, rgba(129, 140, 248, 0.18) 0%, rgba(255, 133, 162, 0.12) 100%);
    border-color: rgba(129, 140, 248, 0.35);
    box-shadow: 
      0 10px 25px -5px rgba(129, 140, 248, 0.2),
      0 8px 10px -6px rgba(0, 0, 0, 0.05);
  }
  .cv-btn-content {
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }
  .download-icon {
    font-size: 1.7rem;
    color: var(--accent-color-1);
    animation: bounceIcon 2.5s infinite ease-in-out;
  }
  @keyframes bounceIcon {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-4px);
    }
  }
  .cv-btn-text {
    text-align: left;
  }
  .cv-btn-text h3 {
    font-size: 1.1rem;
    font-weight: 800;
  }
  .cv-btn-text p {
    font-size: 0.85rem;
    opacity: 0.7;
  }
  .arrow-down {
    color: var(--accent-color-1);
    opacity: 0.5;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
  .cv-download-button:hover .arrow-down {
    opacity: 0.9;
    transform: translateY(4px);
  }
</style>
</BaseLayout>