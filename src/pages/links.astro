---
import BaseLayout from '../layouts/base.astro';
---
<BaseLayout title="Altri link" description="I miei contatti, profili e risorse">
  <div class="links-page-wrapper">

    <div class="links-content">  
      <div class="links-grid">
        <!-- Section 1: Code & Competitive Programming -->
        <div class="links-section">
          <h2><span class="section-emoji">💻</span> Codice & Competizioni</h2>
          <div class="cards-list">
            <a href="https://github.com/LaMatematica14" class="link-card" target="_blank" rel="noopener noreferrer">
              <div class="card-icon">
                <i class="material-icons">code</i>
              </div>
              <div class="card-text">
                <h3>GitHub</h3>
                <p>I miei sorgenti, progetti e repository</p>
              </div>
              <div class="card-arrow">
                <i class="material-icons">east</i>
              </div>
            </a>
            <a href="https://training.olinfo.it/user/LaMatematica14" class="link-card cp-card">
              <div class="card-icon">
                <i class="material-icons">code</i>
              </div>
              <div class="card-text">
                <h3>Olinfo Training</h3>
                <p>Profilo di allenamento delle OII</p>
              </div>
              <div class="card-arrow">
                <i class="material-icons">east</i>
              </div>
            </a>
            <a href="https://codeforces.com/profile/LaMatematica14" class="link-card">
              <div class="card-icon">
                <i class="material-icons">code</i>
              </div>
              <div class="card-text">
                <h3>Codeforces</h3>
                <p>Piattaforma internazionale di programmazione competitiva</p>
              </div>
              <div class="card-arrow">
                <i class="material-icons">east</i>
              </div>
            </a>
          </div>
        </div>
        <!-- Section 2: Socials & Contact -->
        <div class="links-section">
          <h2><span class="section-emoji">🌐</span> Social & Contatti</h2>
          <div class="cards-list">
            <a href="https://it.linkedin.com/in/sofia-marag%C3%B2-5507bb34b" class="link-card linkedin-card">
              <div class="card-icon">
                <i class="material-icons">people</i>
              </div>
              <div class="card-text">
                <h3>LinkedIn</h3>
                <p>Rete professionale e connessioni</p>
              </div>
              <div class="card-arrow">
                <i class="material-icons">east</i>
              </div>
            </a>
            <a href="mailto:sofia.marago@gmail.com" class="link-card email-card">
              <div class="card-icon">
                <i class="material-icons">email</i>
              </div>
              <div class="card-text">
                <h3>Scrivimi un'e-mail</h3>
                <p>sofia.marago@gmail.com</p>
              </div>
              <div class="card-arrow">
                <i class="material-icons">mail_outline</i>
              </div>
            </a>
          </div>
        </div>
        <!-- Section 3: CV & Download -->
        <div class="links-section cv-section">
          <h2><span class="section-emoji">📄</span> Curriculum Vitae</h2>
          <a href="#" class="cv-download-button">
            <div class="cv-btn-content">
              <i class="material-icons download-icon">download</i>
              <div class="cv-btn-text">
                <h3>Scarica il mio CV</h3>
                <p>Formato PDF — Aggiornato a Maggio 2026</p>
              </div>
            </div>
            <i class="material-icons arrow-down">arrow_downward</i>
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
<style>
  .links-page-wrapper {
    position: relative;
    width: 100%;
    min-height: 80vh;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding: 2rem 0;
    overflow: hidden;
  }
  /* Whimsical Background Glyphs */
  .whimsical-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }
  .glyph {
    position: absolute;
    top: var(--y);
    left: var(--x);
    font-size: var(--s);
    color: var(--accent-color-1);
    opacity: 0.15;
    font-family: 'JetBrains Mono', monospace;
    animation: drift 10s ease-in-out infinite alternate;
    animation-delay: var(--d);
    user-select: none;
    transition: opacity 0.3s ease;
  }
  @keyframes drift {
    0% {
      transform: translate(0, 0) rotate(0deg);
    }
    100% {
      transform: translate(15px, 20px) rotate(15deg);
    }
  }
  .links-page-wrapper:hover .glyph {
    opacity: 0.25;
    color: var(--accent-color-1);
  }
  .links-content {
    position: relative;
    width: 100%;
    max-width: 650px;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
  }
  /* Profile Header */
  .profile-header {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }
  .avatar-ring {
    position: relative;
    width: 90px;
    height: 90px;
    border-radius: 50%;
    padding: 3px;
    background: linear-gradient(135deg, var(--accent-color-1) 0%, #ff85a2 100%);
    box-shadow: 0 10px 25px -5px rgba(129, 140, 248, 0.4);
    animation: rotateRing 8s linear infinite;
  }
  @keyframes rotateRing {
    100% {
      transform: rotate(360deg);
    }
  }
  .avatar-placeholder {
    width: 100%;
    height: 100%;
    background-color: var(--bg-color);
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    animation: counterRotateRing 8s linear infinite;
  }
  @keyframes counterRotateRing {
    100% {
      transform: rotate(-360deg);
    }
  }
  .avatar-initials {
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--text-color);
    letter-spacing: -1px;
    font-family: system-ui, -apple-system, sans-serif;
  }
  .profile-header h1 {
    font-size: 2.4rem;
    font-weight: 800;
    color: var(--text-color);
    margin-top: 0.5rem;
  }
  .subtitle {
    font-size: 1.05rem;
    opacity: 0.8;
    font-weight: 500;
  }
  /* Links Grid & Sections */
  .links-grid {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }
  .links-section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .links-section h2 {
    font-size: 1.1rem;
    font-weight: 700;
    opacity: 0.85;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .section-emoji {
    font-size: 1.3rem;
  }
  .cards-list {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  /* Link Card - Beautiful Glassmorphic Styles */
  .link-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.1rem 1.4rem;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.45);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(128, 128, 128, 0.12);
    border-radius: 16px;
    color: var(--text-color) !important;
    box-shadow: 
      0 4px 6px -1px rgba(0, 0, 0, 0.02),
      0 10px 15px -3px rgba(0, 0, 0, 0.03);
    transition: 
      transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), 
      background-color 0.25s ease, 
      border-color 0.25s ease,
      box-shadow 0.3s ease;
  }
  @media (prefers-color-scheme: dark) {
    .link-card {
      background: rgba(1, 9, 28, 0.45);
      border-color: rgba(255, 255, 255, 0.06);
    }
  }
  .link-card:hover {
    transform: translateY(-4px) scale(1.015);
    background: rgba(255, 255, 255, 0.7);
    border-color: rgba(129, 140, 248, 0.3);
    box-shadow: 
      0 10px 20px -5px rgba(129, 140, 248, 0.15),
      0 8px 8px -6px rgba(0, 0, 0, 0.05);
  }
  @media (prefers-color-scheme: dark) {
    .link-card:hover {
      background: rgba(1, 9, 28, 0.7);
      border-color: rgba(129, 140, 248, 0.3);
      box-shadow: 
        0 10px 20px -5px rgba(129, 140, 248, 0.3),
        0 8px 8px -6px rgba(0, 0, 0, 0.05);
    }
  }
  .card-icon {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background-color: rgba(129, 140, 248, 0.08);
    color: var(--accent-color-1);
    transition: transform 0.3s ease, background-color 0.3s ease, color 0.3s ease;
  }
  .link-card:hover .card-icon {
    transform: rotate(8deg) scale(1.1);
    background-color: var(--accent-color-1);
    color: #fff;
  }
  .card-text {
    flex: 1;
    margin-left: 1.2rem;
    text-align: left;
  }
  .card-text h3 {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.15rem;
  }
  .card-text p {
    font-size: 0.85rem;
    opacity: 0.7;
    font-weight: 400;
    line-height: 1.4;
  }
  .card-arrow {
    display: flex;
    align-items: center;
    color: var(--text-color);
    opacity: 0.3;
    transition: opacity 0.25s ease, transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .link-card:hover .card-arrow {
    opacity: 0.8;
    color: var(--accent-color-1);
    transform: translateX(5px);
  }
  /* CV Download Button Styling */
  .cv-download-button {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.2rem 1.5rem;
    text-decoration: none;
    background: linear-gradient(135deg, rgba(129, 140, 248, 0.12) 0%, rgba(255, 133, 162, 0.08) 100%);
    border: 1px solid rgba(129, 140, 248, 0.2);
    border-radius: 18px;
    color: var(--text-color) !important;
    box-shadow: 
      0 4px 15px -3px rgba(129, 140, 248, 0.06);
    transition: 
      transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), 
      background 0.3s ease, 
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }
  .cv-download-button:hover {
    transform: translateY(-4px) scale(1.015);
    background: linear-gradient(135deg, rgba(129, 140, 248, 0.18) 0%, rgba(255, 133, 162, 0.12) 100%);
    border-color: rgba(129, 140, 248, 0.35);
    box-shadow: 
      0 10px 25px -5px rgba(129, 140, 248, 0.2),
      0 8px 10px -6px rgba(0, 0, 0, 0.05);
  }
  .cv-btn-content {
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }
  .download-icon {
    font-size: 1.7rem;
    color: var(--accent-color-1);
    animation: bounceIcon 2.5s infinite ease-in-out;
  }
  @keyframes bounceIcon {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-4px);
    }
  }
  .cv-btn-text {
    text-align: left;
  }
  .cv-btn-text h3 {
    font-size: 1.1rem;
    font-weight: 800;
  }
  .cv-btn-text p {
    font-size: 0.85rem;
    opacity: 0.7;
  }
  .arrow-down {
    color: var(--accent-color-1);
    opacity: 0.5;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
  .cv-download-button:hover .arrow-down {
    opacity: 0.9;
    transform: translateY(4px);
  }
</style>
</BaseLayout>