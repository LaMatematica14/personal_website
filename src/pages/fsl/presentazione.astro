---
import BaseLayout from '../../layouts/base.astro';
---

<BaseLayout title="Presentazione FSL" description="La mia presentazione di formazione scuola-lavoro">
  <div class="presentation-container">
    <div class="presentation-wrapper" id="pdf-container">
      <div class="controls">
        <button id="fullscreen-btn" class="btn">
          <i class="material-icons">fullscreen</i>
        </button>
      </div>
      <iframe src="/PresentazioneFSL.pdf" class="pdf-frame" id="pdf-iframe" allowfullscreen></iframe>
    </div>
  </div>
</BaseLayout>

<script>
  const container = document.getElementById('pdf-container');
  const btn = document.getElementById('fullscreen-btn');

  if (container && btn) {
    btn.addEventListener('click', () => {
      if (!document.fullscreenElement) {
        container.requestFullscreen().catch(err => {
          console.error(`Errore nell'attivazione dello schermo intero: ${err.message}`);
        });
      } else {
        document.exitFullscreen();
      }
    });

    document.addEventListener('fullscreenchange', () => {
      if (document.fullscreenElement === container) {
        btn.innerHTML = '<i class="material-icons">fullscreen_exit</i>';
      } else {
        btn.innerHTML = '<i class="material-icons">fullscreen</i>';
      }
    });
  }
</script>

<style>
  .presentation-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 4rem 2rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .intro-section {
    text-align: center;
    margin-bottom: 2.5rem;
    width: 100%;
  }

  .intro-section h1 {
    font-size: 2.2rem;
    margin-bottom: 0.75rem;
    font-weight: 700;
  }

  .intro-section p {
    font-size: 1.05rem;
    opacity: 0.8;
    max-width: 600px;
    margin: 0 auto;
  }

  .presentation-wrapper {
    width: 100%;
    background: var(--bg-color);
    border: 1px solid rgba(128, 128, 128, 0.15);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.08);
    display: flex;
    flex-direction: column;
  }

  /* Fullscreen styles */
  .presentation-wrapper:fullscreen {
    width: 100vw;
    height: 100vh;
    border: none;
    border-radius: 0;
    padding: 0;
    background: #000;
  }

  .controls {
    padding: 0.75rem 1.2rem;
    background: rgba(128, 128, 128, 0.04);
    border-bottom: 1px solid rgba(128, 128, 128, 0.15);
    display: flex;
    justify-content: flex-end;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--accent-color-1);
    color: #fff;
    border: none;
    padding: 0.5rem 1.1rem;
    border-radius: 8px;
    font-family: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s ease, transform 0.1s ease;
  }

  .btn:hover {
    background-color: var(--accent-color-2);
  }

  .pdf-frame {
    width: 100%;
    height: 70vh;
    border: none;
    background: #525659; /* PDF viewer typical background */
  }

  .presentation-wrapper:fullscreen .pdf-frame {
    height: calc(100vh - 54px); /* Subtract height of the control bar */
  }

  @media (max-width: 768px) {
    .presentation-container {
      padding: 2rem 1rem;
    }
    
    .intro-section h1 {
      font-size: 1.8rem;
    }

    .pdf-frame {
      height: 55vh;
    }
  }
</style>
