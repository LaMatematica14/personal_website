---
import PageLayout from '../../layouts/pages.astro';
import Item from '../../components/item-description.astro'
import LinkCard from '../../components/horiz_link_card.astro'
---

<PageLayout title = "Progetti notevoli scolastici" 
    subtitle="Dei molti lavori che ho svolto nel contesto scolastico nel mio percorso ho scelto qui di includere i più significativi e formativi.">
    <div class="item-list">
        <Item title="Java Chess GUI" date="primavera 2025" photo="/progetti/scolastici/chess.jpg">
            Nato da un progetto di informatica ho espanso la guida ufficiale proposta dal professore sulla progettazione
            di un'interfaccia grafica con feature aggiuntive, ad esempio la possibilità di giocare con un avversario computerizzato
            tramite Stockfish e la variante Antichess.
        </Item>
        <LinkCard 
            link = "/https://github.com/LaMatematica14/Chess" 
            title = "Link all'elaborato" 
            text = "Clicca qui per vedere il mio codice su GitHub."
            icon = "code"
            target = "_blank"
        />
    </div>
</PageLayout>

<style>
  .item-list {
    margin: 4rem;
    display: flex;
    flex-direction: column;
    gap: 5rem;
  }

  .cards-list {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }


  @media (max-width: 868px) {

    .gallery-section {
      margin-top: 3.5rem;
    }

    .gallery-divider {
      margin-bottom: 2rem;
    }

    .gallery-section h2 {
      font-size: 1.4rem;
      margin-bottom: 1.5rem;
    }

    .photo-grid {
      column-count: 1; /* Su mobile le foto vanno in un'unica colonna */
      column-gap: 0;
    }
  }
</style>
