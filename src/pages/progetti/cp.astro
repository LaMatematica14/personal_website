---
import PageLayout from '../../layouts/pages.astro';
import Item from '../../components/item-description.astro'
import ItemVertical from '../../components/item-description-vertical.astro'
import LinkCard from '../../components/horiz_link_card.astro'
---

<PageLayout title="Progetti nel contesto della programmazione competitiva" subtitle="Una raccolta dei lavori più interessanti che ho svolto nel contesto delle Olimpiadi di Informatica">
    <div class="item-list">
        <Item title="Soluzioni e commenti su problemi EGOI24" date="estate 2024" photo="/olinfo/EGOI/egoi2024.jpg">
            Dopo aver partecipato alle EGOI nell'anno 2024, ho deciso di scrivere un compendio di soluzioni svolte e commentate ai problemi che mi sono trovata
            in gara, a scopo principalmente autodidattico. Questo è anche stato il mio primo grande progetto in Latex e grazie ad esso ho approfondito la mia conoscenza
            di questo formato di scrittura scientifica.
        </Item>
        <LinkCard 
            link = "/progetti/cp/SoluzioniEGOI24.pdf" 
            title = "Link all'elaborato" 
            text = "Clicca qui per vedere il compendio in formato pdf."
            icon = "file_present"
            target = "_blank"
        />

        <ItemVertical title="Volontariato SWERC" date="Novembre 2025" photo="/progetti/cp/palloncini_swerc.jpg" dir="row-reverse">
            Quest'anno scolastico ho anche avuto modo di svolgere un'attività di volontariato nel constesto della gara a squadre di programmazione 
            competitiva per università, le ICPC, in particolare per le Regional Finals dell'Europa sud-occidentale, le SWERC.
            <br>
            Quest'esperienza è stata per me molto formativa perché mi ha fatto conoscere da vicino i procedimenti dell'organizzazione
             di un evento internazionale. I quattro giorni che ho trascorso all'università di Pisa per questo evento hanno anche avuto un valore orientativo
            per me, essendo il dipartimento di matematica dell'università una delle mie scelte per la formazione terziaria.
        </ItemVertical>

        <br>

        <Item title="Lezioni e gare del corso PreEGOI" date="Dicembre 2025 - Marzo 2026" photo="/progetti/cp/logo.jpg">
            Come da tradizione, essendo state le EGOI quest'anno organizzate in casa, l'Italia ha avuto la possibilità di portare una seconda squadra 
            alla competizione. Ho partecipato al processo di preparazione e selezione di questa squadra, collaborando con staff delle Olimpiadi, 
            tramite il progetto PreEGOI. Infatti ho tenuto alcune lezioni e ho preparato una parte dei problemi nelle gare di allenamento e selezione.
        </Item>
        <div class="cards-list">
          <LinkCard 
            link = "https://youtube.com/playlist?list=PLe45jMbg4-IR5zQYgg9CAA5GqbZokSUmn&si=1Js6VLirtq144_0X" 
            title = "Video delle lezioni del corso" 
            text = "Clicca qui per trovare le mie lezioni del corso PreEGOI sul canale Youtube di ANPC (Associazione Nazionale Programmazione Competitiva)."
            icon = "video_library"
            target = "_blank"
          />

          <LinkCard 
            link = "https://drive.google.com/drive/folders/1RxRqeXqGOmDbaNaGJQ47ZksEqbm7JuBM?usp=drive_link" 
            title = "Testi dei problemi di gara" 
            text = "Clicca qui per scoprire i problemi della gara finale di selezione della squadra italiana EGOI26."
            icon = "file_present"
            target = "_blank"
          />
        </div>
    </div>
</PageLayout>

<style>
  .item-list {
    margin: 4rem;
    display: flex;
    flex-direction: column;
    gap: 5rem;
  }

  .cards-list {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }


  @media (max-width: 868px) {

    .gallery-section {
      margin-top: 3.5rem;
    }

    .gallery-divider {
      margin-bottom: 2rem;
    }

    .gallery-section h2 {
      font-size: 1.4rem;
      margin-bottom: 1.5rem;
    }

    .photo-grid {
      column-count: 1; /* Su mobile le foto vanno in un'unica colonna */
      column-gap: 0;
    }
  }
</style>
