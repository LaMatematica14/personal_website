  },
  {
    id: "alessandria",
    name: "Alessandria",
    country: "Egitto",
    date: "Settembre 2024",
    x: 474.64,
    y: 450.58,
    description: "IOI 2024. Partecipazione alle Olimpiadi Internazionali di Informatica rappresentando la squadra del Lussemburgo, nel quale ho studiato durante l'anno scolastico 2023/24.",
    photos: ["/ioi_mascotte.jpg"]
  },
  {
    id: "lussemburgo",
    name: "Lussemburgo",
    country: "Lussemburgo",
    date: "A.S. 2023/2024",
    x: 420.43,
    y: 397.56,
    description: "Un anno scolastico trascorso all'estero studiando in Lussemburgo, che mi ha permesso di arricchire il mio percorso accademico, conoscere una nuova cultura e qualificarmi per le IOI 2024.",
    photos: ["/code.jpg"]
  },
  {
    id: "senigallia",
