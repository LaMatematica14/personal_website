      initMap(true);
      return;
    } else if (area === 'europe') {
      // Europe centroid coordinates: ~430, ~395
      const localX = 430 - viewBoxOffsetX;
      const localY = 395 - viewBoxOffsetY;
      targetScale = Math.min(rect.width / 150, 4.5);
      targetX = rect.width / 2 - localX * targetScale;
      targetY = rect.height / 2 - localY * targetScale;
    } else if (area === 'italy') {
      // Italy centroid: ~430, ~412
      const localX = 430 - viewBoxOffsetX;
      const localY = 412 - viewBoxOffsetY;
      targetScale = Math.min(rect.width / 45, 9.5);
      targetX = rect.width / 2 - localX * targetScale;
      targetY = rect.height / 2 - localY * targetScale;
    }

    scale = targetScale;
    translateX = targetX;
    translateY = targetY;
    
    clampTranslate();
    applyTransform();
  }

  function resetFocusButtons() {
    focusBtns.forEach(btn => btn.classList.remove('active'));
  }

  // Mouse Drag / Touch Drag controls
  function onPointerDown(e: MouseEvent | TouchEvent) {
    isDragging = true;
    
    const clientX = 'touches' in e ? e.touches[0].clientX : e.clientX;
    const clientY = 'touches' in e ? e.touches[0].clientY : e.clientY;
    
    startX = clientX;
    startY = clientY;
    lastTranslateX = translateX;
    lastTranslateY = translateY;
    
    if (viewport) {
      viewport.style.cursor = 'grabbing';
    }
  }

  function onPointerMove(e: MouseEvent | TouchEvent) {
    if (!isDragging) return;
    
    const clientX = 'touches' in e ? e.touches[0].clientX : e.clientX;
    const clientY = 'touches' in e ? e.touches[0].clientY : e.clientY;
    
    const dx = clientX - startX;
    const dy = clientY - startY;
    
    translateX = lastTranslateX + dx;
    translateY = lastTranslateY + dy;
    
    clampTranslate();
    applyTransform(true); // make dragging responsive without transition lag
  }

  function onPointerUp() {
    isDragging = false;
    if (viewport) {
      viewport.style.cursor = 'grab';
    }
  }

  // Mouse Wheel scroll-to-zoom
  function onWheel(e: WheelEvent) {
    e.preventDefault();
    const factor = e.deltaY < 0 ? 1.15 : 1 / 1.15;
    zoom(factor, e.clientX, e.clientY);
  }

  // Display trip details inside card
  function displayTripDetails(id: string) {
    const trip = cities.find(c => c.id === id);
    if (!trip || !tripCardContent) return;

    // Build photo elements (excluding the first photo which is displayed as the main item-photo)
    let photosHtml = '';
    if (trip.photos && trip.photos.length > 1) {
      photosHtml = `
        <div class="trip-photos">
          ${trip.photos.slice(1).map(p => `<img src="${p}" alt="${trip.name}" class="trip-photo" />`).join('')}
        </div>
      `;
    }

    // Find country ID from country name
    const countryId = Object.keys(countryNames).find(key => countryNames[key].toLowerCase() === trip.country.toLowerCase());
    const backBtnHtml = countryId ? `
      <button class="back-to-country-btn" data-country-id="${countryId}">
        <i class="material-icons" style="font-size: 1rem; vertical-align: middle; margin-right: 4px;">arrow_back</i>
        Elenco ${trip.country}
      </button>
    ` : '';

    // Insert trip content matching the Item template
    tripCardContent.innerHTML = `
      ${backBtnHtml}
      <div class="item">
        <div class="image-wrapper">
          <img src="${trip.photos[0]}" alt="${trip.name}" class="item-photo" />
        </div>
        <div class="content-wrapper">
          <span class="item-date">${trip.date}, ${trip.country}</span>
          <h2>${trip.name}</h2>
          <p>${trip.description}</p>
        </div>
      </div>
      ${photosHtml}
    `;

    // Make card active
    if (tripCard) {
      tripCard.classList.add('active');
    }
  }

  // Map country ID to display name
  const countryNames: Record<string, string> = {
    'it': 'Italia',
    'ch': 'Svizzera',
    'de': 'Germania',
    'nl': 'Paesi Bassi',
    'se': 'Svezia',
    'eg': 'Egitto',
    'lu': 'Lussemburgo',
    'gb': 'Regno Unito',
    'es': 'Spagna',
    'pl': 'Polonia'
  };

  // Country centers and zoom scales relative to viewport width
  const countryViews: Record<string, { x: number, y: number, scaleFactor: number }> = {
    'it': { x: 430, y: 412, scaleFactor: 45 },      // smaller scaleFactor means higher zoom
    'ch': { x: 425.03, y: 404.68, scaleFactor: 20 },
    'de': { x: 421.68, y: 393.76, scaleFactor: 30 },
    'nl': { x: 417.76, y: 391.42, scaleFactor: 20 },
    'se': { x: 438, y: 360, scaleFactor: 55 },
    'eg': { x: 476, y: 452, scaleFactor: 45 },
    'lu': { x: 420.43, y: 397.56, scaleFactor: 12 },
    'gb': { x: 404.92, y: 390.28, scaleFactor: 25 },
    'es': { x: 408, y: 423, scaleFactor: 35 },
    'pl': { x: 452.5, y: 391.0, scaleFactor: 25 }
  };

  // Zoom map smoothly to country coordinates
  function zoomToCountry(countryId: string) {
    const view = countryViews[countryId];
    if (!view || !viewport) return;
    
    const rect = viewport.getBoundingClientRect();
    const targetScale = Math.min(rect.width / view.scaleFactor, 12);
    
    const localX = view.x - viewBoxOffsetX;
    const localY = view.y - viewBoxOffsetY;
    
    const targetX = rect.width / 2 - localX * targetScale;
    const targetY = rect.height / 2 - localY * targetScale;
    
    scale = targetScale;
    translateX = targetX;
    translateY = targetY;
    
    clampTranslate();
    applyTransform();
  }

  // Clear map highlights and close details card
  function clearSelection() {
    if (tripCard) {
      tripCard.classList.remove('active');
    }
    const pins = document.querySelectorAll('.pin');
    pins.forEach(p => p.classList.remove('active'));
    
    const countries = document.querySelectorAll('.interactive-country');
    countries.forEach(c => c.classList.remove('active-country'));
  }

  // Display list of cities in a clicked country
  function displayCountryDetails(countryId: string) {
    const countryName = countryNames[countryId];
    if (!countryName || !tripCardContent) return;

    // Filter cities visited in this country
    const countryCities = cities.filter(c => c.country.toLowerCase() === countryName.toLowerCase());

    const listHtml = `
      <div class="item">
        <div class="content-wrapper">
          <span class="item-date">Nazioni visitate</span>
          <h2>${countryName}</h2>
          <div class="trip-stats-badge">
            <i class="material-icons" style="font-size: 0.95rem; margin-right: 4px; color: var(--accent-color-1); vertical-align: middle;">explore</i>
            <span style="vertical-align: middle;">${countryCities.length} ${countryCities.length === 1 ? 'città visitata' : 'città visitate'}</span>
          </div>
        </div>
      </div>
      <div class="trip-card-divider"></div>
      <ul class="country-city-list">
        ${countryCities.map(c => `
          <li class="city-item" data-city-id="${c.id}">
            <div class="city-info">
              <span class="city-name">${c.name}</span>
              <span class="city-date">${c.date}</span>
            </div>
            <i class="material-icons city-arrow-icon">chevron_right</i>
          </li>
        `).join('')}
      </ul>
    `;

    tripCardContent.innerHTML = listHtml;
    
    if (tripCard) {
      tripCard.classList.add('active');
    }
  }

  // Highlight the targeted country shape on the SVG
  function highlightCountry(id: string) {
    const countries = document.querySelectorAll('.interactive-country');
    countries.forEach(c => c.classList.remove('active-country'));
    
    const target = document.getElementById(id);
    if (target) {
      target.classList.add('active-country');
    }
  }

  // Select a pinpoint: highlight it and zoom in on it
  function selectPin(id: string) {
    // Highlight pin in SVG
    const pins = document.querySelectorAll('.pin');
    pins.forEach(p => p.classList.remove('active'));
    
    const targetPin = document.getElementById(`pin-${id}`);
    if (targetPin) {
      targetPin.classList.add('active');
    }

    // Centering point with zoom animation
    const trip = cities.find(c => c.id === id);
    if (trip && viewport) {
      const rect = viewport.getBoundingClientRect();
      
      // Target scale for zoom-to-city
      const targetScale = Math.min(rect.width / 90, 7.5);
      
      // Target coordinates
      const localX = trip.x - viewBoxOffsetX;
      const localY = trip.y - viewBoxOffsetY;
      const targetX = rect.width / 2 - localX * targetScale;
      const targetY = rect.height / 2 - localY * targetScale;

      scale = targetScale;
      translateX = targetX;
      translateY = targetY;
      
      clampTranslate();
      applyTransform();
      
      // Update details card
      displayTripDetails(id);
      resetFocusButtons();
    }
  }

  // Event Listeners
  if (viewport) {
    viewport.addEventListener('mousedown', onPointerDown);
    window.addEventListener('mousemove', onPointerMove);
    window.addEventListener('mouseup', onPointerUp);
    
    viewport.addEventListener('touchstart', onPointerDown, { passive: true });
    window.addEventListener('touchmove', onPointerMove, { passive: true });
    window.addEventListener('touchend', onPointerUp);

    viewport.addEventListener('wheel', onWheel, { passive: false });
  }

  // Setup click handler for SVG paths and Pinpoints
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    
    // 1. Check if clicked on a pinpoint or its children
    const pin = target.closest('.pin');
    if (pin) {
      const id = pin.getAttribute('data-id');
      if (id) {
        selectPin(id);
      }
      return;
    }

    // 2. Check if clicked on a city list item inside the details card
    const cityItem = target.closest('.city-item');
    if (cityItem) {
      const cityId = cityItem.getAttribute('data-city-id');
      if (cityId) {
        selectPin(cityId);
      }
      return;
    }

    // Check if clicked on the back button
    const backBtn = target.closest('.back-to-country-btn');
    if (backBtn) {
      const countryId = backBtn.getAttribute('data-country-id');
      if (countryId) {
        displayCountryDetails(countryId);
        highlightCountry(countryId);
        zoomToCountry(countryId);
        
        // Remove pin active states
        const pins = document.querySelectorAll('.pin');
        pins.forEach(p => p.classList.remove('active'));
      }
      return;
    }

    // 3. Check if clicked on a country path shape
    const countryPath = target.closest('path, g');
    if (countryPath) {
      // Find if this path belongs to a visited country
      let current: HTMLElement | null = countryPath as HTMLElement;
      let targetId: string | null = null;
      while (current && current.tagName !== 'svg') {
        const id = current.getAttribute('id');
        if (id && countryNames[id.toLowerCase()]) {
          targetId = id.toLowerCase();
          break;
        }
        current = current.parentElement;
      }
                       
      if (targetId) {
        displayCountryDetails(targetId);
        highlightCountry(targetId);
        zoomToCountry(targetId);
        
        // Remove pin active states
        const pins = document.querySelectorAll('.pin');
        pins.forEach(p => p.classList.remove('active'));
        return;
      }
    }
    
    // Handle image lightbox overlay open
    if (target.classList.contains('trip-photo')) {
      const src = target.getAttribute('src');
      if (src && lightboxImg && lightbox) {
        lightboxImg.src = src;
        lightbox.classList.add('active');
      }
      return;
    }

    // 4. Clicked outside active elements but inside viewport wrapper -> clear selection
    const clickedCard = target.closest('.trip-details-card');
    const clickedZoom = target.closest('.zoom-controls');
    const clickedFocus = target.closest('.focus-bar');
    const clickedViewport = target.closest('.map-viewport-wrapper');
    
    if (clickedViewport && !clickedCard && !clickedZoom && !clickedFocus) {
      clearSelection();
    }
  });

  // Close Card Button handler
  if (closeCardBtn) {
    closeCardBtn.addEventListener('click', () => {
      clearSelection();
    });
  }

  // Hover Tooltip triggers
  document.addEventListener('mouseover', (e) => {
    const target = e.target as HTMLElement;
    
    // Check pin hover first
    const pin = target.closest('.pin');
    if (pin && tooltip) {
      const name = pin.getAttribute('data-name') || '';
      tooltip.textContent = name;
      tooltip.classList.add('active');
      return;
    }
    
    // Check country hover
    const country = target.closest('.interactive-country');
    if (country && tooltip) {
      const id = country.getAttribute('id');
      const name = id ? countryNames[id.toLowerCase()] : '';
      if (name) {
        tooltip.textContent = name;
        tooltip.classList.add('active');
      }
    }
  });

  document.addEventListener('mousemove', (e) => {
    if (tooltip && tooltip.classList.contains('active') && viewport) {
      const rect = viewport.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      tooltip.style.left = `${x}px`;
      tooltip.style.top = `${y}px`;
    }
  });

  document.addEventListener('mouseout', (e) => {
    const target = e.target as HTMLElement;
    const pin = target.closest('.pin');
    const country = target.closest('.interactive-country');
    
    if ((pin || country) && tooltip) {
      tooltip.classList.remove('active');
    }
  });

  // Zoom Button Controls click triggers
  if (zoomInBtn) {
    zoomInBtn.addEventListener('click', () => zoom(1.3));
  }
  if (zoomOutBtn) {
    zoomOutBtn.addEventListener('click', () => zoom(1 / 1.3));
  }
  if (zoomResetBtn) {
    zoomResetBtn.addEventListener('click', () => {
      initMap(true);
      clearSelection();
    });
  }

  // Focus Button Controls triggers
  focusBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      resetFocusButtons();
      btn.classList.add('active');
      const area = btn.getAttribute('data-focus') || 'world';
      focusArea(area);
      clearSelection();
    });
  });

  // Full-Screen Image Lightbox triggers
  if (lightboxClose) {
    lightboxClose.addEventListener('click', () => {
      if (lightbox) lightbox.classList.remove('active');
    });
  }
  if (lightbox) {
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) {
        lightbox.classList.remove('active');
      }
    });
  }

  // Window Resize re-adjusts
  window.addEventListener('resize', () => {
    // Store current percentage center before resize
    if (!viewport) return;
    const vRect = viewport.getBoundingClientRect();
    const mapCenterX = (vRect.width / 2 - translateX) / scale;
    const mapCenterY = (vRect.height / 2 - translateY) / scale;
    
    // Fit map scale
    initMap(false);
    
    // Restore center
    translateX = vRect.width / 2 - mapCenterX * scale;
    translateY = vRect.height / 2 - mapCenterY * scale;
    clampTranslate();
    applyTransform(true);
  });

  // Mark visited countries as interactive
  const visitedCountries = ['it', 'ch', 'de', 'nl', 'se', 'eg', 'lu', 'gb', 'es', 'pl'];
  visitedCountries.forEach(id => {
    const el = document.getElementById(id);
    if (el) {
      el.classList.add('interactive-country');
    }
  });

  // Start initialization
  initMap(true);
</script>
