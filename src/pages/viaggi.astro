  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxClose = document.getElementById('lightbox-close') as HTMLElement;

  const mapWidth = 784.077;
  const mapHeight = 458.627;
  const viewBoxOffsetX = 30.767;
  const viewBoxOffsetY = 241.591;

  // State
  let scale = 1;
  let translateX = 0;
  let translateY = 0;
  
  let isDragging = false;
  let startX = 0;
  let startY = 0;
  let lastTranslateX = 0;
  let lastTranslateY = 0;

  let minScale = 0.5;
  const maxScale = 15;

  // Initialize view: fit map to viewport
  function initMap(center = true) {
    if (!viewport || !container) return;
    const vRect = viewport.getBoundingClientRect();
    
    // Fit map to viewport
    const scaleX = vRect.width / mapWidth;
    const scaleY = vRect.height / mapHeight;
    const fitScale = Math.min(scaleX, scaleY);
    
    minScale = fitScale; // Prevent zooming out further than the initial fit
    scale = fitScale;
    
    if (center) {
      translateX = (vRect.width - mapWidth * scale) / 2;
      translateY = (vRect.height - mapHeight * scale) / 2;
    }
    
    applyTransform(true); // instant initialization
  }

  // Update SVG transform
  function applyTransform(instant = false) {
    if (!container) return;
    
    if (instant) {
      gsap.set(container, {
        x: translateX,
        y: translateY,
        scale: scale
      });
      updatePinsScale();
    } else {
      gsap.to(container, {
        x: translateX,
        y: translateY,
        scale: scale,
        duration: 0.3,
        ease: "power2.out",
        onUpdate: () => {
          updatePinsScale();
        }
      });
    }
  }

  // Keep pins size constant regardless of map zoom scale
  function updatePinsScale() {
    if (!container) return;
    const pins = document.querySelectorAll('.pin');
    const currentScale = (gsap.getProperty(container, "scale") as number) || scale || 1;
    const pinScale = 0.8 / currentScale;
    pins.forEach(pin => {
      const x = pin.getAttribute('data-x');
      const y = pin.getAttribute('data-y');
      if (x && y) {
        pin.setAttribute('transform', `translate(${x}, ${y}) scale(${pinScale})`);
      }
    });
  }

  // Linear map bounds clamping
  function clampTranslate() {
    if (!viewport) return;
    const vRect = viewport.getBoundingClientRect();
    
    const marginX = vRect.width * 0.7;
    const marginY = vRect.height * 0.7;

    const minX = -mapWidth * scale + marginX;
    const maxX = vRect.width - marginX;
    const minY = -mapHeight * scale + marginY;
    const maxY = vRect.height - marginY;

    translateX = Math.min(Math.max(translateX, minX), maxX);
    translateY = Math.min(Math.max(translateY, minY), maxY);
  }

  // Smooth zoom function
  function zoom(factor: number, clientX?: number, clientY?: number) {
    if (!viewport) return;
    const newScale = scale * factor;
    const nextScale = Math.min(Math.max(newScale, minScale), maxScale);
    
    // Zoom around target coordinates or viewport center
    let zoomX = 0;
    let zoomY = 0;
    
    const rect = viewport.getBoundingClientRect();
    if (clientX !== undefined && clientY !== undefined) {
      zoomX = clientX - rect.left;
      zoomY = clientY - rect.top;
    } else {
      zoomX = rect.width / 2;
      zoomY = rect.height / 2;
    }
    
    // Position of zoom point in map coordinates
    const mapX = (zoomX - translateX) / scale;
    const mapY = (zoomY - translateY) / scale;
    
    // Adjust translations
    translateX = zoomX - mapX * nextScale;
    translateY = zoomY - mapY * nextScale;
    scale = nextScale;
    
    clampTranslate();
    applyTransform();
    resetFocusButtons();
  }

