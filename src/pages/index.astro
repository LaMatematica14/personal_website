---
// Welcome to Astro! Everything between these triple-dash code fences
// is your "component frontmatter". It never runs in the browser.
console.log('This runs in your terminal, not the browser!');
import BaseLayout from '../layouts/base.astro';
import Desc_Box from '../components/short_description_box.astro'
//import '@fontsource/terminus';

---


<BaseLayout title="Sofia Maragò" description="La mia pagina principale.">
  <section class = "spacing">
    <h1> Benvenut* al mio sito! <br><hr> Sono Sofia Maragò. </h1>
  </section> 

  <section class = "main-content">
    
    <div class="featured-links">
      <h2 style="font-family: 'Terminus', Courier, 'Courier New', monospace;"> 
        Se è la prima volta che siete qui ecco alcune pagine consigliate: 
      </h2>
      <div class="card-grid">
        <Desc_Box link = '/about' img = '/me.jpg' >
          <h3> Mi presento in due parole </h3>
        </Desc_Box>
        <Desc_Box link = '/fsl/google' img = '/fsl/google/google_hq.jpg' >
          <h3> Vi racconto la mia esperienza di FSL a Google Zurigo (CH)</h3>
        </Desc_Box>

        <Desc_Box link = '/progetti/f1inschools' img = '/progetti/f1inschools/f1_building_stand.jpg' >
          <h3> Vi racconto la mia partecipazione a F1inSchools </h3>
        </Desc_Box>

        <Desc_Box link = '/olinfo/intro' img = '/olinfo/olinfo2025.jpg' >
          <h3> Vi racconto la mia esperienza alle Olimpiadi di informatica </h3>
        </Desc_Box>
      </div>
  </div>
  </section>

  

  <style>
    body{
      background-image: url("/background.png");
      background-size: 100%; 
      background-position: center;
    }

    .spacing {
      display: flex;
      background-color: rgba(0, 0, 0, 0.7);
      padding: 3rem 4rem;
      align-items: center;
      justify-content: center;
      min-height: 600px;
      font-family: 'Terminus', Courier, 'Courier New', monospace;
      font-size: 50px;
    }

    .spacing h1{
      text-align: center;
    }

    .main-content {
      background-color: var(--bg-color);
    }

    .featured-links {
      flex: 1;
      padding: 3rem 4rem;
    }

    .card-grid {
      padding: 3rem 0rem;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
      gap: 1rem;
    }
  </style>
</BaseLayout>

